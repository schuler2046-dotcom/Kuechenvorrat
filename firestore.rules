rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Zugriff nur für (anonym) angemeldete Nutzer der App.
    // Der Haushalts-Code im Pfad wirkt als gemeinsames Geheimnis:
    // Nur wer ihn kennt, findet die Dokumente des Haushalts.
    match /households/{household}/data/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
